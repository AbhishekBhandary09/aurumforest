    let card='';
    try{
      const d=JSON.parse(m[1]);
      card=`<div class="itin-card">`;
      if(d.destination) card+=`<div style="font-size:.95rem;color:var(--gold-light);font-family:'Cormorant Garamond',serif;margin-bottom:10px">✦ ${d.destination} · ${d.duration}</div>`;
      if(d.theme) card+=`<div style="font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:10px">${d.theme}</div>`;
      if(d.days) d.days.forEach(dy=>{ card+=`<div class="itin-card-day"><div class="itin-day-num">Day ${dy.day}</div><div class="itin-day-text"><span class="itin-day-hi">${dy.title}</span>${dy.activities}</div></div>`; });
      if(d.accommodation) card+=`<div style="margin-top:10px;padding-top:10px;border-top:1px solid rgba(201,168,76,.15);font-size:.75rem;color:var(--slate)">🏨 ${d.accommodation}</div>`;
      if(d.priceFrom) card+=`<div style="margin-top:6px;font-size:.8rem;color:var(--gold-light)">From ${d.priceFrom}</div>`;
      card+=`</div>`;
    }catch(e){card='';}
    return (pre?`<p style="margin-bottom:10px">${pre}</p>`:'')+card+(post?`<p style="margin-top:10px">${post}</p>`:'');
  }
 
  async function sendMsg(){
    const txt=input.value.trim();
    if(!txt||busy) return;
    busy=true;input.value='';input.style.height='auto';
    document.getElementById('c-sugg').style.display='none';
    addMsg(txt,'user');showTyping();
    history.push({role:'user',content:txt});
    try{
      const res=await fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:SYS,messages:history})
      });
      const data=await res.json();
      hideTyping();
      const reply=data.content?.[0]?.text||'Apologies — something went wrong. Please try again.';
      history.push({role:'assistant',content:reply});
      addMsg(renderItinerary(reply),'assistant');
    }catch(e){hideTyping();addMsg('Apologies, I cannot connect right now. Please try again in a moment.','assistant');}
    busy=false;
  }
 
  send.addEventListener('click',sendMsg);
  input.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();}});
  input.addEventListener('input',()=>{input.style.height='auto';input.style.height=Math.min(input.scrollHeight,80)+'px';});
})();
 
/* ═══════════════════════════════════════════════════
   INTERSECTION OBSERVERS (reveal + timeline)
═══════════════════════════════════════════════════ */
const ro=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');}),{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));
const to=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');}),{threshold:.3});
document.querySelectorAll('.timeline-item').forEach(el=>to.observe(el));
 
// Late cursor hook for dynamically added elements
setTimeout(()=>document.querySelectorAll('.dest-card,.card-btn,.slider-btn,.masonry-item,.globe-dest-item,.social-link,.footer-links a,.nav-links a').forEach(cHover),600);
</script>
