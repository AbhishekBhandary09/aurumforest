!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AurumForest — Luxury Travel & Expeditions</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
    /* ─── CSS Variables mutated by Golden Hour engine ─── */
    :root {
      --forest:       #1a2e1a;
      --forest-mid:   #243824;
      --forest-light: #2d4a2d;
      --forest-pale:  #3d5e3d;
      --gold:         #c9a84c;
      --gold-light:   #e2c97e;
      --gold-pale:    #f0dfa0;
      --gold-glow:    0.4;
      --slate:        #8a9ba8;
      --slate-light:  #b0bec8;
      --cream:        #f5f0e8;
      --white:        #ffffff;
      --glass-bg:     rgba(26,46,26,0.45);
      --glass-border: rgba(201,168,76,0.2);
      --card-bg:      rgba(36,56,36,0.7);
    }
    body.mode-dawn {
      --forest:       #1e2030; --forest-mid:   #252840;
      --gold:         #e8a055; --gold-light:   #f5c07a;
      --gold-glow:    0.7;     --glass-border: rgba(232,160,85,0.28);
    }
    body.mode-dusk {
      --forest:       #1a1428; --forest-mid:   #231830;
      --gold:         #d4824a; --gold-light:   #e8a870;
      --gold-glow:    0.85;    --glass-border: rgba(212,130,74,0.3);
    }
    body.mode-night {
      --forest:       #0d1018; --forest-mid:   #141820;
      --gold:         #8899cc; --gold-light:   #aabbdd;
      --gold-glow:    0.25;    --glass-border: rgba(136,153,204,0.18);
    }
 
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--forest); color: var(--cream);
      overflow-x: hidden; cursor: none;
      transition: background 2s ease, color 2s ease;
    }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--forest); }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 2px; }
 
    /* ── Cursor ── */
    #cursor {
      position:fixed; width:12px; height:12px; background:var(--gold);
      border-radius:50%; pointer-events:none; z-index:9999;
      transform:translate(-50%,-50%);
      transition:width .25s, height .25s, background .25s;
    }
    #cursor-ring {
      position:fixed; width:36px; height:36px; border:1.5px solid var(--gold);
      border-radius:50%; pointer-events:none; z-index:9998;
      transform:translate(-50%,-50%); opacity:.6;
      transition:width .4s, height .4s, opacity .3s;
    }
    #cursor.ex { width:20px; height:20px; background:var(--gold-light); }
    #cursor-ring.ex { width:56px; height:56px; opacity:.3; }
 
    /* ── Time Badge ── */
    #time-badge {
      position:fixed; top:24px; right:80px; z-index:1100;
      display:flex; align-items:center; gap:8px; padding:6px 14px;
      background:rgba(26,46,26,0.7); backdrop-filter:blur(12px);
      border:1px solid var(--glass-border);
      font-size:.6rem; letter-spacing:.2em; text-transform:uppercase;
      color:var(--gold-light); pointer-events:none;
      opacity:0; animation:fadeIn 1s 2s ease forwards;
      transition:all 1s ease;
    }
    #time-badge .dot { width:6px; height:6px; border-radius:50%; background:var(--gold); box-shadow:0 0 8px var(--gold); animation:badgePulse 2s infinite; }
    @keyframes badgePulse{0%,100%{opacity:1}50%{opacity:.4}}
    @keyframes fadeIn{to{opacity:1}}
 
    /* ── Navbar ── */
    #navbar {
      position:fixed; top:0; left:0; right:0; z-index:1000;
      padding:24px 48px; display:flex; align-items:center; justify-content:space-between;
      transition:all .5s ease;
    }
    #navbar.scrolled {
      background:rgba(20,32,20,0.82); backdrop-filter:blur(20px);
      padding:16px 48px; border-bottom:1px solid var(--glass-border);
    }
    .nav-logo { font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-weight:400; color:var(--gold-light); letter-spacing:.12em; text-transform:uppercase; }
    .nav-logo span { color:var(--white); }
    .nav-links { display:flex; gap:36px; list-style:none; }
    .nav-links a { font-size:.75rem; letter-spacing:.2em; text-transform:uppercase; color:var(--slate-light); text-decoration:none; transition:color .3s; position:relative; }
    .nav-links a::after { content:''; position:absolute; bottom:-4px; left:0; width:0; height:1px; background:var(--gold); transition:width .3s; }
    .nav-links a:hover { color:var(--gold-light); }
    .nav-links a:hover::after { width:100%; }
    .mag-wrap { display:inline-block; position:relative; cursor:none; }
    .nav-cta {
      font-size:.7rem; letter-spacing:.2em; text-transform:uppercase;
      color:var(--forest); background:var(--gold); padding:10px 24px; border:none;
      font-family:'DM Sans',sans-serif; cursor:none; transition:background .3s;
    }
    .nav-cta:hover { background:var(--gold-light); }
    .nav-mobile-toggle { display:none; flex-direction:column; gap:5px; cursor:none; background:none; border:none; }
    .nav-mobile-toggle span { width:24px; height:1px; background:var(--gold-light); }
 
    /* ── Hero ── */
    #hero { position:relative; height:100vh; min-height:700px; display:flex; align-items:flex-end; overflow:hidden; }
    .hero-bg { position:absolute; inset:0; background:url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=85') center 30%/cover; transform:scale(1.06); animation:heroZoom 18s ease-in-out infinite alternate; }
    @keyframes heroZoom{from{transform:scale(1.06)}to{transform:scale(1)}}
    .hero-overlay { position:absolute; inset:0; background:linear-gradient(to bottom,rgba(20,32,20,.2) 0%,rgba(20,32,20,.1) 40%,rgba(20,32,20,.7) 75%,rgba(20,32,20,.97) 100%); transition:background 2s; }
    body.mode-dawn  .hero-overlay { background:linear-gradient(to bottom,rgba(30,32,48,.25) 0%,rgba(30,32,48,.12) 40%,rgba(30,32,48,.78) 75%,rgba(30,32,48,.97) 100%); }
    body.mode-dusk  .hero-overlay { background:linear-gradient(to bottom,rgba(60,20,10,.25) 0%,rgba(40,20,15,.15) 40%,rgba(26,20,40,.82) 75%,rgba(26,20,40,.97) 100%); }
    body.mode-night .hero-overlay { background:linear-gradient(to bottom,rgba(10,12,24,.35) 0%,rgba(10,12,24,.2) 40%,rgba(13,16,24,.88) 75%,rgba(13,16,24,.97) 100%); }
    .hero-content { position:relative; z-index:2; width:100%; padding:0 48px 80px; }
    .hero-eyebrow { font-size:.7rem; letter-spacing:.35em; text-transform:uppercase; color:var(--gold); margin-bottom:20px; opacity:0; animation:fadeUp 1s .4s ease forwards; }
    .hero-title { font-family:'Cormorant Garamond',serif; font-size:clamp(3.5rem,8vw,7rem); font-weight:300; line-height:1; color:var(--white); max-width:800px; margin-bottom:28px; opacity:0; animation:fadeUp 1s .6s ease forwards; }
    .hero-title em { font-style:italic; color:var(--gold-light); }
    .hero-sub { font-size:1rem; color:var(--slate-light); max-width:500px; line-height:1.7; margin-bottom:44px; font-weight:300; opacity:0; animation:fadeUp 1s .8s ease forwards; }
    .search-bar { display:flex; background:rgba(26,46,26,.55); backdrop-filter:blur(24px); border:1px solid var(--glass-border); max-width:780px; opacity:0; animation:fadeUp 1s 1s ease forwards; }
    .search-field { flex:1; padding:18px 24px; border-right:1px solid var(--glass-border); }
    .search-field:last-of-type { border-right:none; }
    .search-label { font-size:.6rem; letter-spacing:.2em; text-transform:uppercase; color:var(--gold); margin-bottom:4px; }
    .search-input { background:transparent; border:none; outline:none; color:var(--white); font-family:'DM Sans',sans-serif; font-size:.9rem; width:100%; cursor:none; }
    .search-input::placeholder { color:var(--slate); }
    .search-btn { background:var(--gold); border:none; padding:0 36px; color:var(--forest); font-family:'DM Sans',sans-serif; font-size:.7rem; font-weight:500; letter-spacing:.2em; text-transform:uppercase; cursor:none; white-space:nowrap; transition:background .3s, box-shadow .3s; }
    .search-btn:hover { background:var(--gold-light); box-shadow:0 0 28px rgba(201,168,76,.5); }
    @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
 
    /* ── Sections ── */
    section { padding:120px 48px; }
    .section-eyebrow { font-size:.65rem; letter-spacing:.35em; text-transform:uppercase; color:var(--gold); margin-bottom:16px; }
    .section-title { font-family:'Cormorant Garamond',serif; font-size:clamp(2.2rem,4vw,3.5rem); font-weight:300; line-height:1.15; color:var(--white); margin-bottom:16px; }
    .section-title em { font-style:italic; color:var(--gold-light); }
    .section-desc { color:var(--slate-light); font-weight:300; line-height:1.75; max-width:520px; font-size:.95rem; }
    .gold-line { width:48px; height:1px; background:var(--gold); margin-bottom:24px; }
    .reveal { opacity:0; transform:translateY(40px); transition:all .8s cubic-bezier(.25,.46,.45,.94); }
    .reveal.visible { opacity:1; transform:translateY(0); }
    .reveal-delay-1 { transition-delay:.1s; }
    .reveal-delay-2 { transition-delay:.2s; }
    .reveal-delay-3 { transition-delay:.3s; }
 
    /* ── Destinations ── */
    #destinations { background:var(--forest-mid); }
    .destinations-header { display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:56px; flex-wrap:wrap; gap:24px; }
    .slider-controls { display:flex; gap:12px; }
    .slider-btn { width:48px; height:48px; border:1px solid var(--glass-border); background:var(--glass-bg); color:var(--gold); display:flex; align-items:center; justify-content:center; cursor:none; transition:all .3s; font-size:1.2rem; }
    .slider-btn:hover { background:var(--gold); color:var(--forest); }
    .cards-wrapper { overflow:hidden; }
    .cards-track { display:flex; gap:24px; transition:transform .6s cubic-bezier(.25,.46,.45,.94); }
    .dest-card { min-width:340px; flex-shrink:0; position:relative; overflow:hidden; border:1px solid var(--glass-border); transition:transform .5s cubic-bezier(.25,.46,.45,.94), box-shadow .5s; cursor:none; }
    .dest-card:hover { transform:translateY(-12px) scale(1.01); box-shadow:0 30px 60px rgba(0,0,0,.5); }
    .dest-card:hover .card-img { transform:scale(1.08); }
    .card-img { width:100%; height:440px; object-fit:cover; display:block; transition:transform .7s cubic-bezier(.25,.46,.45,.94); }
    .card-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(20,32,20,.96) 0%,rgba(20,32,20,.2) 55%,transparent 100%); }
    .card-body { position:absolute; bottom:0; left:0; right:0; padding:28px; }
    .card-tag { display:inline-block; font-size:.6rem; letter-spacing:.2em; text-transform:uppercase; color:var(--forest); background:var(--gold); padding:4px 12px; margin-bottom:12px; }
    .card-location { font-size:.65rem; letter-spacing:.2em; text-transform:uppercase; color:var(--gold); margin-bottom:6px; }
    .card-title { font-family:'Cormorant Garamond',serif; font-size:1.7rem; font-weight:400; color:var(--white); margin-bottom:8px; }
    .card-meta { display:flex; align-items:center; justify-content:space-between; margin-top:16px; }
    .card-price { font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-weight:300; color:var(--gold-light); }
    .card-price span { font-size:.7rem; font-family:'DM Sans',sans-serif; color:var(--slate); }
    .card-btn { font-size:.65rem; letter-spacing:.15em; text-transform:uppercase; color:var(--forest); background:var(--gold); border:none; padding:9px 20px; font-family:'DM Sans',sans-serif; font-weight:500; cursor:none; transition:background .3s, box-shadow .3s; }
    .card-btn:hover { background:var(--gold-light); box-shadow:0 0 22px rgba(201,168,76,.6); }
 
    /* ── Globe ── */
    #globe-section { background:var(--forest); padding:120px 48px; position:relative; overflow:hidden; }
    #globe-section::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 70% 50%,rgba(201,168,76,.04) 0%,transparent 70%); pointer-events:none; }
    .globe-layout { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; max-width:1400px; margin:0 auto; }
    .globe-destinations { margin-top:48px; display:flex; flex-direction:column; gap:1px; background:var(--glass-border); }
    .globe-dest-item { display:flex; align-items:center; gap:20px; padding:18px 24px; background:var(--forest); cursor:none; transition:background .3s; border-left:2px solid transparent; }
    .globe-dest-item:hover,.globe-dest-item.active { background:rgba(201,168,76,.06); border-left-color:var(--gold); }
    .globe-dest-dot { width:8px; height:8px; border-radius:50%; background:var(--gold); flex-shrink:0; box-shadow:0 0 8px rgba(201,168,76,.6); transition:transform .3s, box-shadow .3s; }
    .globe-dest-item:hover .globe-dest-dot,.globe-dest-item.active .globe-dest-dot { transform:scale(1.5); box-shadow:0 0 16px rgba(201,168,76,.9); }
    .globe-dest-name { font-family:'Cormorant Garamond',serif; font-size:1.1rem; color:var(--white); }
    .globe-dest-coords { font-size:.65rem; letter-spacing:.15em; color:var(--slate); margin-left:auto; }
    .globe-right { position:relative; display:flex; align-items:center; justify-content:center; }
    #globe-canvas { width:100%; max-width:600px; aspect-ratio:1; display:block; cursor:grab; }
    #globe-canvas:active { cursor:grabbing; }
    .globe-ring-1,.globe-ring-2 { position:absolute; border-radius:50%; border:1px solid rgba(201,168,76,.12); pointer-events:none; }
    .globe-ring-1 { width:110%; aspect-ratio:1; animation:globeSpin 20s linear infinite; }
    .globe-ring-2 { width:125%; aspect-ratio:1; border-style:dashed; animation:globeSpin 35s linear infinite reverse; }
    @keyframes globeSpin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
    .globe-glow { position:absolute; width:60%; aspect-ratio:1; border-radius:50%; background:radial-gradient(circle,rgba(201,168,76,.08) 0%,transparent 70%); pointer-events:none; }
    .globe-label { position:absolute; bottom:-32px; left:50%; transform:translateX(-50%); font-size:.6rem; letter-spacing:.3em; text-transform:uppercase; color:var(--slate); white-space:nowrap; }
    .globe-active-pin { position:absolute; top:20px; right:20px; background:rgba(26,46,26,.85); backdrop-filter:blur(16px); border:1px solid var(--glass-border); padding:16px 20px; min-width:200px; opacity:0; transform:translateY(8px); transition:all .4s; pointer-events:none; }
    .globe-active-pin.visible { opacity:1; transform:translateY(0); }
    .globe-pin-label { font-size:.6rem; letter-spacing:.2em; text-transform:uppercase; color:var(--gold); margin-bottom:4px; }
    .globe-pin-name { font-family:'Cormorant Garamond',serif; font-size:1.1rem; color:var(--white); }
    .globe-controls-hint { display:flex; align-items:center; gap:20px; margin-top:32px; padding-top:24px; border-top:1px solid var(--glass-border); }
    .hint-item { display:flex; align-items:center; gap:8px; font-size:.7rem; color:var(--slate); }
    .hint-icon { width:28px; height:28px; border:1px solid var(--glass-border); display:flex; align-items:center; justify-content:center; font-size:.8rem; }
 
    /* ── Itinerary ── */
    #itinerary { background:var(--forest); }
    .itinerary-grid { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start; }
    .timeline { position:relative; padding-left:48px; }
    .timeline::before { content:''; position:absolute; left:14px; top:20px; bottom:20px; width:1px; background:linear-gradient(to bottom,var(--gold),rgba(201,168,76,.1)); }
    .timeline-item { position:relative; margin-bottom:48px; opacity:0; transform:translateX(-20px); transition:all .6s; }
    .timeline-item.visible { opacity:1; transform:translateX(0); }
    .timeline-dot { position:absolute; left:-40px; top:4px; width:28px; height:28px; background:var(--forest-mid); border:1px solid var(--gold); display:flex; align-items:center; justify-content:center; font-size:.75rem; color:var(--gold); transition:all .4s; }
    .timeline-item.visible .timeline-dot { background:var(--gold); color:var(--forest); box-shadow:0 0 20px rgba(201,168,76,.4); }
    .timeline-day { font-size:.6rem; letter-spacing:.25em; text-transform:uppercase; color:var(--gold); margin-bottom:6px; }
    .timeline-event { font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:var(--white); margin-bottom:6px; }
    .timeline-desc { font-size:.85rem; color:var(--slate-light); line-height:1.7; font-weight:300; }
    .itin-img { position:sticky; top:120px; }
    .itin-img img { width:100%; height:580px; object-fit:cover; border:1px solid var(--glass-border); }
    .itin-img-caption { padding:20px 24px; background:var(--card-bg); border:1px solid var(--glass-border); border-top:none; }
    .itin-img-caption h4 { font-family:'Cormorant Garamond',serif; font-size:1.2rem; color:var(--white); margin-bottom:4px; }
    .itin-img-caption p { font-size:.8rem; color:var(--slate); }
 
    /* ── Gallery ── */
    #gallery { background:var(--forest-mid); }
    .gallery-header { display:grid; grid-template-columns:1fr 1fr; gap:48px; margin-bottom:64px; align-items:end; }
    .masonry-grid { columns:4; column-gap:16px; }
    .masonry-item { break-inside:avoid; margin-bottom:16px; position:relative; overflow:hidden; cursor:none; }
    .masonry-item img { width:100%; display:block; transition:transform .7s cubic-bezier(.25,.46,.45,.94); }
    .masonry-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(20,32,20,.9) 0%,transparent 50%); opacity:0; transition:opacity .4s; display:flex; flex-direction:column; justify-content:flex-end; padding:20px; }
    .masonry-item:hover img { transform:scale(1.1); }
    .masonry-item:hover .masonry-overlay { opacity:1; }
    .masonry-traveler { font-family:'Cormorant Garamond',serif; font-size:1rem; color:var(--white); }
    .masonry-location { font-size:.65rem; letter-spacing:.15em; text-transform:uppercase; color:var(--gold); }
    .stat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--glass-border); margin-top:64px; }
    .stat-item { background:var(--forest-mid); padding:36px 32px; text-align:center; }
    .stat-number { font-family:'Cormorant Garamond',serif; font-size:3rem; font-weight:300; color:var(--gold-light); line-height:1; margin-bottom:8px; }
    .stat-label { font-size:.65rem; letter-spacing:.2em; text-transform:uppercase; color:var(--slate); }
 
    /* ── Footer ── */
    footer { background:var(--forest); border-top:1px solid var(--glass-border); padding:80px 48px 40px; }
    .footer-grid { display:grid; grid-template-columns:1.6fr 1fr 1fr 1.4fr; gap:48px; margin-bottom:64px; }
    .footer-brand-name { font-family:'Cormorant Garamond',serif; font-size:1.6rem; font-weight:300; color:var(--gold-light); letter-spacing:.1em; text-transform:uppercase; margin-bottom:16px; }
    .footer-brand-desc { font-size:.85rem; color:var(--slate); line-height:1.8; font-weight:300; margin-bottom:28px; }
    .social-links { display:flex; gap:12px; }
    .social-link { width:36px; height:36px; border:1px solid var(--glass-border); display:flex; align-items:center; justify-content:center; color:var(--slate); font-size:.8rem; transition:all .3s; text-decoration:none; cursor:none; }
    .social-link:hover { border-color:var(--gold); color:var(--gold); }
    .footer-col-title { font-size:.65rem; letter-spacing:.25em; text-transform:uppercase; color:var(--gold); margin-bottom:24px; }
    .footer-links { list-style:none; display:flex; flex-direction:column; gap:12px; }
    .footer-links a { font-size:.85rem; color:var(--slate); text-decoration:none; transition:color .3s; font-weight:300; cursor:none; }
    .footer-links a:hover { color:var(--gold-light); }
    .newsletter-form { display:flex; border:1px solid var(--glass-border); }
    .newsletter-input { flex:1; background:transparent; border:none; outline:none; padding:14px 18px; color:var(--white); font-family:'DM Sans',sans-serif; font-size:.85rem; cursor:none; }
    .newsletter-input::placeholder { color:var(--slate); }
    .newsletter-btn { background:var(--gold); border:none; padding:14px 20px; color:var(--forest); font-size:.75rem; letter-spacing:.15em; text-transform:uppercase; font-family:'DM Sans',sans-serif; font-weight:500; cursor:none; transition:background .3s; }
    .newsletter-btn:hover { background:var(--gold-light); }
    .newsletter-note { font-size:.72rem; color:var(--slate); margin-top:12px; line-height:1.6; }
    .footer-bottom { border-top:1px solid var(--glass-border); padding-top:32px; display:flex; align-items:center; justify-content:space-between; }
    .footer-copy { font-size:.72rem; color:var(--slate); letter-spacing:.1em; }
    .footer-copy span { color:var(--gold); }
    .footer-bottom-links { display:flex; gap:28px; }
    .footer-bottom-links a { font-size:.72rem; color:var(--slate); text-decoration:none; cursor:none; transition:color .3s; }
    .footer-bottom-links a:hover { color:var(--gold-light); }
 
    /* ── AI Concierge ── */
    #concierge-fab {
      position:fixed; bottom:36px; right:36px; z-index:2000;
      width:60px; height:60px; background:var(--gold); border:none; border-radius:50%;
      display:flex; align-items:center; justify-content:center; cursor:none;
      box-shadow:0 8px 32px rgba(0,0,0,.4); transition:background .3s, transform .3s;
      animation:fabPulse 3s ease infinite;
    }
